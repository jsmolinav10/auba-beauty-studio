# ============================================
# AUBA Beauty Studio — Production Environment
# ============================================
# Copy this file to .env and fill in ALL values before deploying

# ---- Database ----
DB_HOST=your-mysql-host.com
DB_USER=auba_user
DB_PASSWORD=STRONG_PASSWORD_HERE
DB_NAME=auba_studio

# ---- Server ----
PORT=3000
NODE_ENV=production

# ---- Security ----
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---- Admin Credentials ----
ADMIN_PHONE=YOUR_REAL_ADMIN_PHONE
ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD

# ---- ePayco Payments ----
# Get these from https://epayco.com after registration
EPAYCO_PUBLIC_KEY=your_epayco_public_key
EPAYCO_PRIVATE_KEY=your_epayco_private_key
EPAYCO_P_KEY=your_epayco_p_key
EPAYCO_TEST_MODE=false

# ---- WhatsApp Business API (Optional) ----
# Get from Meta Business: https://developers.facebook.com/
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ---- Email / SMTP ----
# For Gmail: use smtp.gmail.com, port 587, and generate an App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_real_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=AUBA Beauty Studio <your_real_email@gmail.com>

# ---- Site URL ----
SITE_URL=https://yourdomain.com
